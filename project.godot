; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[GDExcelExporter]

SettingsDir="res://Datatable"
cmd_path="res://Datatable/ee.exe"

[application]

config/name="Godot Mota Template (Kitchen Group 出品)"
config/name_localized={
"en": "Godot Standard Mota Template",
"ja": "テンプレート",
"zh": "魔塔样板"
}
config/version="1.0.0"
run/main_scene="uid://bjgqr8olramsd"
config/custom_user_dir_name="Godot\\app_userdata\\Godot Standard Mota Template"
config/features=PackedStringArray("4.5", "GL Compatibility")
run/max_fps=60
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
boot_splash/fullsize=false

[audio]

buses/default_bus_layout="uid://dbxo47qnfhnpn"

[autoload]

PlatformWrapper="*res://Script/PlatformWrapper.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=960
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/AutotileCreate/plugin.cfg", "res://addons/GDExcelExporter/plugin.cfg", "res://addons/i18nForMota/plugin.cfg", "res://addons/mota/plugin.cfg")

