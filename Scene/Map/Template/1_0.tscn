    \"type\": \"actionArr\",
    \"actions\": [
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"这里是一个例子，用于快速清理之前章节的所有数据！\\n和我对话完就会自动把对应章节的地图内容全部重置\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"一定要注意：\\n输入的参数是你将要到达的章节id而非想要清除的章节id！\"
        },
        {
            \"type\": \"script\",
            \"script\": \"MotaSystem.mapManager.next_chapter_end(1)\"
        }
    ]
}"
