[node name="Page1" type="Sprite2D" parent="Events/NPC11"]
texture = ExtResource("6_wulmg")
centered = false
hframes = 4
vframes = 4
script = ExtResource("7_xxyxb")
text = "{
    \"type\": \"actionArr\",
    \"actions\": [
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"来试一试变量操作\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"在编辑器中按Ctrl+P快捷打开GameVariables.gd这个脚本，在其中可以直观的看到各个变量的初始化\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"在这里建议每一个变量都要记得初始化并附伤注释！否则你一定会忘了变量的作用的\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"在初始化完成后，事件中直接使用变量操作即可\\n请注意，变量操作的左侧必须为\\\"变量ID\\\"这一表达式！\"
        },
        {
            \"type\": \"setValue\",
            \"name\": {
                \"type\": \"idStringExpr\",
                \"id\": \"temp\"
            },
            \"op\": \"=\",
            \"value\": {
                \"type\": \"evalStringExpr\",
                \"v\": \"2\"
            }
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"在我身后就是一个根据变量判定出现的黄钥匙\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"可以用作通用的\\\"根据某变量出现\\\"的事件模板使用\\n比如根据难度出现的额外资源\"
        }
    ]
}"
