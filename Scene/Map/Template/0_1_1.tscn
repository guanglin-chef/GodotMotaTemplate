[node name="NPC9" type="VisibleOnScreenNotifier2D" parent="Events"]
position = Vector2(448, 128)
rect = Rect2(0, 0, 64, 64)
script = ExtResource("3_wulmg")

[node name="Page1" type="Sprite2D" parent="Events/NPC9"]
texture = ExtResource("6_wulmg")
centered = false
hframes = 4
vframes = 4
script = ExtResource("7_xxyxb")
text = "{
    \"type\": \"actionArr\",
    \"actions\": [
        {
            \"type\": \"showText\",
            \"name\": \"屑老头\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"试一试条件分歧\"
        },
        {
            \"type\": \"ifAction\",
            \"condition\": {
                \"type\": \"evalStringExpr\",
                \"v\": \"1+1==2\"
            },
            \"trueActions\": [
                {
                    \"type\": \"showText\",
                    \"name\": \"\",
                    \"face\": \"\",
                    \"textPos\": \"Down\",
                    \"backGround\": true,
                    \"text\": \"true\"
                }
            ],
            \"falseActions\": [
                {
                    \"type\": \"showText\",
                    \"name\": \"\",
                    \"face\": \"\",
                    \"textPos\": \"Down\",
                    \"backGround\": true,
                    \"text\": \"false\"
                }
            ]
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"表达式需要使用事件表达！你直接代码输入一个表达式是无法正常工作的\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"事件编辑器左侧的value里面蕴含了表达式的所有要素，拼就完事了\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"所以正确的写法应该参考下面这个，上面那个是反例\"
        },
        {
            \"type\": \"ifAction\",
            \"condition\": {
                \"type\": \"arithmetic\",
                \"a\": {
                    \"type\": \"arithmetic\",
                    \"a\": {
                        \"type\": \"evalStringExpr\",
                        \"v\": \"1\"
                    },
                    \"op\": \"+\",
                    \"b\": {
                        \"type\": \"evalStringExpr\",
                        \"v\": \"1\"
                    }
                },
                \"op\": \"==\",
                \"b\": {
                    \"type\": \"evalStringExpr\",
                    \"v\": \"2\"
                }
            },
            \"trueActions\": [
                {
                    \"type\": \"showText\",
                    \"name\": \"\",
                    \"face\": \"\",
                    \"textPos\": \"Down\",
                    \"backGround\": true,
                    \"text\": \"true\"
                }
            ],
            \"falseActions\": [
                {
                    \"type\": \"showText\",
                    \"name\": \"\",
                    \"face\": \"\",
                    \"textPos\": \"Down\",
                    \"backGround\": true,
                    \"text\": \"false\"
                }
            ]
        }
    ]
}"
onPageFinished = 2
idleAnim = true
movingAnim = false
noDirection = true
metadata/_custom_type_script = "uid://ck04g2xj2adjp"
metadata/_edit_lock_ = true

