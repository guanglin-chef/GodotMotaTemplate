[node name="Page1" type="Sprite2D" parent="Events/NPC12"]
texture = ExtResource("6_wulmg")
centered = false
hframes = 4
vframes = 4
script = ExtResource("7_xxyxb")
text = "{
    \"type\": \"actionArr\",
    \"actions\": [
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"在表达式中，EvalString_default可以识别直接输入的量，但是不支持代码表达式\\n就比如，你输入2 输入\\\"asd\\\"都可以识别，但是输入 1+1  输入 \\\"a\\\"+\\\"sd\\\"是无法识别的。\"
        },
        {
            \"type\": \"showText\",
            \"name\": \"\",
            \"face\": \"\",
            \"textPos\": \"Down\",
            \"backGround\": true,
            \"text\": \"要想直接输入代码表达式进行判断，请使用脚本\\n就像下面这个例子\"
        },
        {
            \"type\": \"ifAction\",
            \"condition\": {
                \"type\": \"scriptExpr\",
                \"v\": \"1+1==2\"
            },
            \"trueActions\": [
                {
                    \"type\": \"showText\",
                    \"name\": \"\",
                    \"face\": \"\",
                    \"textPos\": \"Down\",
                    \"backGround\": true,
                    \"text\": \"true\"
                }
